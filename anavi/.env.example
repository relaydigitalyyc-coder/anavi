# ANAVI Environment Variables
# Copy to .env.local and fill in values

# --- Required for DB-backed features ---
DATABASE_URL=mysql://user:password@host:port/anavi

# --- Auth ---
JWT_SECRET=change-me-to-a-random-string

# --- Runtime Mode ---
# demo = synthetic auth + demo fixtures (no DB needed)
# hybrid = prelaunch (synthetic fallback, demo fixtures enabled)
# live = real auth required, no demo fixtures
APP_RUNTIME_MODE=demo
VITE_APP_RUNTIME_MODE=demo

# --- Optional: Replit/Forge auth (only if using Replit hosting) ---
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=

# --- Optional: Storage proxy ---
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# --- Optional: AI features ---
# ANTHROPIC_API_KEY=

# --- Optional: DocuSign integration ---
# DOCUSIGN_ENV=demo
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_BASE_URI=
# DOCUSIGN_IMPERSONATED_USER_ID=
# DOCUSIGN_RSA_PRIVATE_KEY=
# DOCUSIGN_CONNECT_HMAC_SECRET=
# DOCUSIGN_EXECUTION_MODE=api
# DOCUSIGN_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/docusign/oauth/callback
# DOCUSIGN_OAUTH_CLIENT_SECRET=
# DOCUSIGN_MCP_URL=
# DOCUSIGN_MCP_CLIENT_ID=
# DOCUSIGN_MCP_CLIENT_SECRET=

# --- Optional: Stripe ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
